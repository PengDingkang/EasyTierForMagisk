#!/system/bin/sh

path="/data/adb/easytier"
bin_name="easytier-core"
pid_file="$path/pid"
config_file="$path/config/config.toml"
autostart_file="$path/autostart.conf"

# find busybox across Magisk/KSU/APatch
for bb in /data/adb/magisk/busybox /data/adb/ksu/bin/busybox /data/adb/ap/bin/busybox; do
  [ -f "$bb" ] && busybox="$bb" && break
done
# fallback to PATH
[ -z "$busybox" ] && busybox="busybox"

bin_status() {
  [ "$($busybox pidof "$bin_name")" ] && return 0 || return 1
}

get_autostart() {
  AUTO_START=1
  # shellcheck disable=SC1090
  [ -f "$autostart_file" ] && . "$autostart_file"
  echo "${AUTO_START:-1}"
}

set_autostart() {
  mkdir -p "$path"
  printf "AUTO_START=%s\n" "$1" > "$autostart_file"
}

# update KSU module description
update_desc() {
  command -v ksud >/dev/null 2>&1 || return
  export KSU_MODULE="EasyTierForMagisk"
  if bin_status; then
    ip=$(grep -m1 'ipv4' "$config_file" 2>/dev/null | sed 's/.*= *"\(.*\)"/\1/')
    ksud module config set override.description "✅ Running | IP: ${ip:-dhcp}" 2>/dev/null
  else
    ksud module config set override.description "⏹ Stopped" 2>/dev/null
  fi
}

display_bin_status() {
  if bin_status; then
    printf "\033[32m● easytier is running (pid: %s)\033[0m\n" "$(cat "$pid_file" 2>/dev/null)"
  else
    printf "\033[31m● easytier is stopped\033[0m\n"
  fi
  if [ "$(get_autostart)" = "1" ]; then
    printf "● boot auto start: enabled\n"
  else
    printf "● boot auto start: disabled\n"
  fi
  update_desc
}

start_service() {
  if bin_status; then
    echo "${bin_name} is already running"
    return
  fi
  if [ ! -f "$config_file" ]; then
    echo "ERROR: config not found at $config_file"
    return 1
  fi
  # set hostname from instance_name before starting
  hn=$(grep -m1 'instance_name' "$config_file" 2>/dev/null | sed 's/.*= *"\(.*\)"/\1/')
  [ -n "$hn" ] && hostname "$hn"
  nohup "$bin_name" -c "$config_file" > /dev/null 2> "$path/error.log" &
  printf '%s' "$!" > "$pid_file"
  sleep 1
  ip rule add from all lookup main pref 1 2>/dev/null
  if bin_status; then
    echo "start success"
    rm -f "$path/.not_configured" 2>/dev/null
  else
    echo "start failed, check /data/adb/easytier/error.log"
  fi
}

stop_service() {
  if bin_status; then
    echo "stopping ${bin_name}..."
    kill "$(cat "$pid_file" 2>/dev/null)" 2>/dev/null || killall "$bin_name" 2>/dev/null
    i=0
    while bin_status && [ $i -lt 20 ]; do
      sleep 0.5
      i=$((i + 1))
    done
    bin_status && kill -9 "$(cat "$pid_file" 2>/dev/null)" 2>/dev/null
    ip rule del from all lookup main pref 1 2>/dev/null
    hostname localhost
  else
    echo "${bin_name} is already stopped"
  fi
  rm -f "$pid_file" 2>/dev/null
}

case "$1" in
  start)     start_service; display_bin_status ;;
  stop)      stop_service; display_bin_status ;;
  restart)   stop_service; start_service; display_bin_status ;;
  status)    display_bin_status ;;
  enable)    set_autostart 1; echo "boot auto start: enabled" ;;
  disable)   set_autostart 0; echo "boot auto start: disabled" ;;
  *)         echo "Usage: easytier {start|stop|restart|status|enable|disable}" ;;
esac
